  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "eslint": "^10.5.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.32.0",
    "firebase-functions-test": "^3.5.0",
    "mocha": "^11.7.6",
    "sinon": "^22.0.0"
  },
  "private": true
}
